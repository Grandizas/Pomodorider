# Supabase
SUPABASE_URL=
SUPABASE_KEY=                    # anon/public key
SUPABASE_SERVICE_ROLE_KEY=       # server-only, never expose to client

# App
# In production set this to the canonical origin (e.g. https://pomodorider.com).
# Used by @nuxtjs/seo for canonical URLs, sitemap, and OG/social tags.
NUXT_PUBLIC_APP_URL=http://localhost:3001

# SEO / OG images. Signs dynamic OG-image generation requests so they can't be
# abused. Generate with: npx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=

# For now not required (used for videos, images)
NUXT_PUBLIC_MEDIA_BASE_URL=
