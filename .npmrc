@awesome.me:registry=https://npm.fontawesome.com/
@fortawesome:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONT_AWESOME_TOKEN}

# @vercel/speed-insights declares optional framework peers (SvelteKit, etc.)
# that npm tries to resolve and conflicts with Nuxt's vite version. These peers
# are irrelevant to this app; legacy-peer-deps lets installs resolve cleanly.
legacy-peer-deps=true
